APP_ENV=development
APP_PORT=8080
APP_SECRET=mangahub-secret-change-in-production

DB_HOST=localhost
DB_PORT=5432
DB_USER=mangahub
DB_PASSWORD=mangahub_password
DB_NAME=mangahub_db
DB_SSLMODE=disable
DATABASE_URL=postgres://mangahub:mangahub_password@localhost:5432/mangahub_db?sslmode=disable

JWT_SECRET=mangahub-jwt-secret-key-32-chars!!
JWT_EXPIRY_HOURS=24

TCP_PORT=9001
UDP_PORT=9002
GRPC_PORT=9003

LOG_LEVEL=info
