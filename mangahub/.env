# MangaHub Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_SECRET=your-super-secret-key-change-this-in-production

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=mangahub
DB_PASSWORD=mangahub_password
DB_NAME=mangahub_db
DB_SSLMODE=disable
DATABASE_URL=postgres://mangahub:mangahub_password@localhost:5432/mangahub_db?sslmode=disable

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-minimum-32-chars
JWT_EXPIRY_HOURS=24

# ─── TCP Server ────────────────────────────────────────────────────────────
TCP_PORT=9001

# ─── UDP Server ────────────────────────────────────────────────────────────
UDP_PORT=9002

# ─── gRPC Server ───────────────────────────────────────────────────────────
GRPC_PORT=9003

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
